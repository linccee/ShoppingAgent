import queue
import threading
import logging

# ── Debug logger — writes to file so Streamlit stdout capture doesn't hide it ──
_log = logging.getLogger("agent_stream")
if not _log.handlers:
    import os
    from datetime import date
    # Create logs directory in project root if it doesn't exist
    log_dir = os.path.join(os.path.dirname(os.path.dirname(__file__)), "logs")
    os.makedirs(log_dir, exist_ok=True)
    today = date.today().strftime("%Y-%m-%d")
    _fh = logging.FileHandler(os.path.join(log_dir, f"{today}_agent_debug.log"), mode="a")
    _fh.setFormatter(logging.Formatter("%(asctime)s %(message)s"))
    _log.addHandler(_fh)
    _log.setLevel(logging.DEBUG)

from langchain_core.callbacks.base import BaseCallbackHandler

from langchain_openai import ChatOpenAI
from langchain_classic.agents import AgentExecutor, create_react_agent
from langchain_classic.memory import ConversationSummaryMemory
from langchain_core.prompts import ChatPromptTemplate
from tools.search_tool import search_products
from tools.price_tool import prices
from tools.review_tool import analyze_reviews
from tools.currency_exchange_tool import currency_exchange
from agent.prompt import SYSTEM_PROMPT
from config import Config


def create_shopping_agent(history: list = None):
    """
    创建并返回购物决策Agent实例。
    每次对话会话开始时调用一次。
    """
    # 1. 初始化LLM
    llm = ChatOpenAI(
        model=Config.MODEL,
        api_key=Config.API_KEY,
        base_url=Config.BASE_URL,
        temperature=Config.TEMPERATURE,
        streaming=True,  # 流式输出，让Streamlit实时显示
        stream_usage=True  # 启用流式响应中的 token 统计
    )

    # 2. 注册工具列表
    tools = [search_products, prices, analyze_reviews, currency_exchange]

    # 3. 构建 ChatPromptTemplate，将三类内容严格分离：
    #    - SystemMessage  : 静态系统指令，只出现一次，不随对话膨胀
    #    - chat_history   : 动态对话历史，由 Memory 在每次调用时注入
    #    - HumanMessage   : 当前用户输入
    #    - agent_scratchpad: ReAct 思考链（也作为消息动态追加）
    react_prompt = ChatPromptTemplate.from_messages([
        ("system", SYSTEM_PROMPT),
        ("system", "对话历史摘要：\n{chat_history}"),
        ("human", "Question: {input}\nThought:{agent_scratchpad}"),
    ])

    # 4. 创建ReAct Agent
    agent = create_react_agent(
        llm=llm,
        tools=tools,
        prompt=react_prompt
    )

    # 5. 创建对话记忆（使用摘要模式，将历史压缩成摘要）
    memory = ConversationSummaryMemory(
        llm=ChatOpenAI(
            model=Config.LITE_MODEL,
            api_key=Config.LITE_API_KEY,
            base_url=Config.LITE_BASE_URL,
            temperature=Config.TEMPERATURE),
        memory_key='chat_history',
        return_messages=False  # 返回字符串而不是 Message 对象
    )

    if history:
        for msg in history:
            if msg.get("role") == "user":
                memory.chat_memory.add_user_message(msg.get("content", ""))
            elif msg.get("role") == "assistant":
                memory.chat_memory.add_ai_message(msg.get("content", ""))

    # 6. 用AgentExecutor包装，处理工具调用循环
    agent_executor = AgentExecutor(
        agent=agent,
        tools=tools,
        memory=memory,
        verbose=Config.VERBOSE,          # True时终端会打印思考过程
        max_iterations=Config.MAX_ITERATIONS,
        handle_parsing_errors=True,  # 解析失败时自动重试
        return_intermediate_steps=True  # 返回每步的工具调用记录
    )

    return agent_executor


def run_agent(agent_executor, user_input: str) -> dict:
    """
    执行Agent，返回结果字典。

    返回格式：
        {
            'output': '最终推荐报告',
            'steps': [{'tool': ..., 'input': ..., 'output': ...}]
        }
    """
    result = agent_executor.invoke({'input': user_input})

    # 整理中间步骤（用于前端展示调用过程）
    steps = []
    for action, observation in result.get('intermediate_steps', []):
        steps.append({
            'tool': action.tool,
            'input': action.tool_input,
            'output': observation[:200] + '...' if len(observation) > 200 else observation
        })

    return {
        'output': result['output'],
        'steps': steps
    }


class _QueueCallback(BaseCallbackHandler):
    """
    将 LLM 令牌和工具事件路由到线程安全的队列。

    两层输出策略：
    第一层（首选）：on_llm_new_token — 逐个令牌进行流式传输。
                    需要 LLM 上启用 streaming=True，并且回调函数
                    必须在 LLM 层注册。
    第二层（备选）：on_agent_finish — 如果没有收到流式令牌，则将完整的最终结果作为单个事件发出。
                确保用户始终可以看到输出。
    """

    def __init__(self, q: queue.Queue, stop_event: threading.Event) -> None:
        super().__init__()
        self._q = q
        self._stop_event = stop_event
        self._got_tokens = False   # True once at least one token was streamed

    def _check_stop(self):
        if self._stop_event.is_set():
            raise Exception("Generation stopped by user")

    # ── Layer 1: streaming tokens ─────────────────────────────────────────────
    def on_llm_new_token(self, token: str, **kwargs) -> None:
        self._check_stop()
        if token:
            _log.debug(f"[TOKEN] {repr(token[:30])}")
            self._got_tokens = True
            self._q.put(("token", token))

    # ── Layer 2: complete-answer fallback ─────────────────────────────────────
    def on_agent_finish(self, finish, **kwargs) -> None:
        """If no tokens were streamed, emit the whole answer now."""
        _log.debug(f"[FINISH] got_tokens={self._got_tokens}")
        if not self._got_tokens:
            output = ""
            if hasattr(finish, "return_values"):
                output = finish.return_values.get("output", "")
            elif isinstance(finish, dict):
                output = finish.get("output", str(finish))
            if output:
                self._q.put(("token", output))

    def on_llm_end(self, response, **kwargs) -> None:
        """Extract token usage after each LLM call and send to queue."""
        try:
            if response.generations and response.generations[0]:
                message = getattr(response.generations[0][0], "message", None)
                if message and hasattr(message, "usage_metadata") and message.usage_metadata:
                    self._q.put(("token_usage", message.usage_metadata))
        except Exception as e:
            _log.debug(f"[LLM_END] Error extracting usage: {e}")

    # ── Tool lifecycle ────────────────────────────────────────────────────────
    def on_tool_start(
        self,
        serialized: dict,
        input_str: str,
        **kwargs,
    ) -> None:
        self._check_stop()
        _log.debug(f"[TOOL_START] {serialized.get('name')}")
        self._q.put(("tool_start", {
            "tool":   serialized.get("name", "unknown"),
            "input":  input_str,
            "output": "",
        }))

    def on_tool_end(self, output: str, **kwargs) -> None:
        _log.debug(f"[TOOL_END] len={len(str(output))}")
        raw = str(output)
        self._q.put(("tool_end", raw[:300] + "…" if len(raw) > 300 else raw))


def stream_agent(agent_executor, user_input: str):
    """
    同步生成器，在后台线程中运行，生成 (kind, data) 事件元组。

    事件种类：
      "token"       str  — 一个 LLM 输出令牌（或作为备选的完整答案）
      "tool_start"  dict — {tool, input, output}
      "tool_end"    str  — 截断的工具输出
      "error"       str  — 异常消息

    回调传播说明：
        使用 agent_executor.__call__(callbacks=[cb])，
        它将回调直接传递给 Chain 的 _call() 方法——这是在 LangChain 各个版本之间实现 AgentExecutor 回调传播的最可靠途径。
    """
    q: queue.Queue = queue.Queue()
    stop_event = threading.Event()
    cb = _QueueCallback(q, stop_event)

    def _run() -> None:
        _log.debug(f"[RUN] thread started, input={repr(user_input[:40])}")
        try:
            # Use __call__ (not invoke) — direct callbacks= arg is more
            # reliably inherited by child LLM calls in AgentExecutor.
            agent_executor(
                {"input": user_input},
                callbacks=[cb],
            )
            _log.debug("[RUN] agent_executor call returned normally")
        except Exception as exc:
            if str(exc) == "Generation stopped by user":
                _log.debug("[RUN] Stopped by user")
            else:
                _log.debug(f"[RUN] EXCEPTION: {exc}")
                q.put(("error", str(exc)))
        finally:
            _log.debug("[RUN] thread finishing, putting sentinel")
            q.put(None)  # sentinel — always fires


    thread = threading.Thread(target=_run, daemon=True)
    thread.start()

    try:
        while True:
            item = q.get()
            if item is None:
                break
            yield item
    except BaseException as e:
        # GeneratorExit is a BaseException, will be caught here if Streamlit stops script
        _log.debug(f"[STREAM] Catching {type(e)}")
        stop_event.set()
        raise
    finally:
        stop_event.set()
        thread.join(timeout=1.0)


if __name__ == '__main__':
    print(run_agent(create_shopping_agent(), ""))

    """
    原先的工具调用：
    
    
    """


